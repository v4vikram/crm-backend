// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MEMBER
}

enum LeadSource {
  WEBSITE
  FACEBOOK
  GOOGLE_ADS
  REFERRAL
  PHONE_CALL
  WALK_IN
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
}

enum NotificationType {
  LEAD_CREATED
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  CHURNED
}

model User {
  id                   String    @id @default(uuid())
  name                 String
  email                String    @unique
  passwordHash         String
  role                 Role      @default(MEMBER)
  passwordResetToken   String?   @unique
  passwordResetExpires DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  assignedLeads     Lead[]         @relation("LeadAssignedTo")
  createdLeads      Lead[]         @relation("LeadCreatedBy")
  assignedCustomers Customer[]     @relation("CustomerAssignedTo")
  createdCustomers  Customer[]     @relation("CustomerCreatedBy")
  notifications     Notification[]

  @@map("users")
}

model Lead {
  id           String     @id @default(uuid())
  companyName  String?
  contactName  String
  email        String?
  phone        String?
  website      String?
  source       LeadSource @default(OTHER)
  status       LeadStatus @default(NEW)
  remarks      String?
  assignedToId String?
  assignedTo   User?      @relation("LeadAssignedTo", fields: [assignedToId], references: [id])
  createdById  String
  createdBy    User       @relation("LeadCreatedBy", fields: [createdById], references: [id])
  lastContactedAt DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  customer Customer?

  @@index([assignedToId])
  @@index([status])
  @@index([source])
  @@index([createdAt])
  @@map("leads")
}

model Customer {
  id           String         @id @default(uuid())
  companyName  String?
  contactName  String
  email        String?
  phone        String?
  address      String?
  dealValue    Float?
  status       CustomerStatus @default(ACTIVE)
  remarks      String?
  assignedToId String?
  assignedTo   User?          @relation("CustomerAssignedTo", fields: [assignedToId], references: [id])
  createdById  String
  createdBy    User           @relation("CustomerCreatedBy", fields: [createdById], references: [id])
  leadId       String         @unique
  lead         Lead           @relation(fields: [leadId], references: [id])
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?

  @@index([assignedToId])
  @@index([status])
  @@index([createdAt])
  @@map("customers")
}

model Notification {
  id         String           @id @default(uuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id])
  type       NotificationType
  title      String
  message    String
  entityType String?
  entityId   String?
  isRead     Boolean          @default(false)
  readAt     DateTime?
  createdAt  DateTime         @default(now())

  @@index([userId, isRead])
  @@map("notifications")
}
